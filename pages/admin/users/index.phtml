<div class="admin-page">
  <nav class="admin-nav">
    <a href="/admin/invites" class="admin-nav-link">Invites</a>
    <a href="/admin/users" class="admin-nav-link active">Users</a>
    <a href="/admin/bots" class="admin-nav-link">Bots</a>
  </nav>

  <h1>Users</h1>

  <section class="admin-section">
    <table class="data-table">
      <thead>
        <tr>
          <th>Handle</th>
          <th>Display name</th>
          <th>Roles</th>
          <th>Joined</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
      {{#each users}}
        <tr>
          <td><code>{{handle}}</code></td>
          <td>{{display_name}}</td>
          <td>
            {{#if isAdmin}}<span class="tag tag--admin">admin</span>{{/if}}
            {{#if isBot}}<span class="tag tag--bot">bot</span>{{/if}}
          </td>
          <td>{{created_at_fmt}}</td>
          <td><a href="/admin/users/{{user_id}}" class="btn-ghost">Edit</a></td>
        </tr>
      {{/each}}
      </tbody>
    </table>
  </section>
</div>
